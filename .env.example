# Sentinel MAS — environment variables
# Copy this file to .env and fill in your values
# Never commit .env to git

# ── LLM ──────────────────────────────────────────────────────────────────────
# Choose one provider
OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...

# ── Database ──────────────────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=sentinel_mas
DB_USER=sentinel
DB_PASSWORD=localdev

# ── AWS (required for deployment, optional for local dev) ────────────────────
AWS_REGION=ap-southeast-1
AWS_ACCOUNT_ID=123456789012

# ── SQS ───────────────────────────────────────────────────────────────────────
# Leave blank for local dev — docker-compose uses LocalStack
SQS_QUEUE_URL=

# ── API ───────────────────────────────────────────────────────────────────────
API_SECRET_KEY=change-me-in-production
API_PORT=8000

# ── UI ────────────────────────────────────────────────────────────────────────
VITE_API_URL=http://localhost:8000

# ── Development flags ─────────────────────────────────────────────────────────
# Set to true to use a stub LLM classifier (avoids API calls during local dev)
MOCK_LLM=false

# Set to debug for verbose agent logging
LOG_LEVEL=info
